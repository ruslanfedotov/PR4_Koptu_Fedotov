<Page x:Class="PR4_Fedotov_Koptu.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 2">
    <ScrollViewer>
        <StackPanel Margin="20">
            <Image Source="task2.png" Height="120" Margin="10" ToolTip="Формула 2"/>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="x:" Width="50" VerticalAlignment="Center"/>
                <TextBox x:Name="txtX" Width="150" Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="m:" Width="50" VerticalAlignment="Center"/>
                <TextBox x:Name="txtM" Width="150" Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="Выбрать f(x):" Width="100" VerticalAlignment="Center"/>
                <RadioButton x:Name="rbSh" Content="sh(x)" Margin="5" GroupName="func"/>
                <RadioButton x:Name="rbX2" Content="x²" Margin="5" GroupName="func" IsChecked="True"/>
                <RadioButton x:Name="rbExp" Content="e^x" Margin="5" GroupName="func"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="Результат:" Width="70" VerticalAlignment="Center"/>
                <TextBox x:Name="txtResult" Width="200" IsReadOnly="True" Background="LightYellow" Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                <Button Content="Вычислить" Width="100" Height="35" Margin="5" Click="BtnCalc_Click"/>
                <Button Content="Очистить" Width="100" Height="35" Margin="5" Click="BtnClear_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>