<Page x:Class="PR4_Fedotov_Koptu.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 1">
    <ScrollViewer>
        <StackPanel Margin="20">
            <Image Source="task1.png" Height="150" Margin="10" ToolTip="Формула 1"/>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="x:" Width="50" VerticalAlignment="Center"/>
                <TextBox x:Name="txtX" Width="150" Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="y:" Width="50" VerticalAlignment="Center"/>
                <TextBox x:Name="txtY" Width="150" Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="z:" Width="50" VerticalAlignment="Center"/>
                <TextBox x:Name="txtZ" Width="150" Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="Результат:" Width="70" VerticalAlignment="Center"/>
                <TextBox x:Name="txtResult" Width="200" IsReadOnly="True" Background="LightYellow" Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                <Button Content="Вычислить" Width="100" Height="35" Margin="5" Click="BtnCalc_Click"/>
                <Button Content="Очистить" Width="100" Height="35" Margin="5" Click="BtnClear_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>