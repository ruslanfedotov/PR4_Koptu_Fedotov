<Window x:Class="PR4_Fedotov_Koptu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4" Height="600" Width="900"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Страница 1" Width="100" Height="30" Margin="5" Click="BtnPage1_Click"/>
            <Button Content="Страница 2" Width="100" Height="30" Margin="5" Click="BtnPage2_Click"/>
            <Button Content="Страница 3" Width="100" Height="30" Margin="5" Click="BtnPage3_Click"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1"/>
    </Grid>
</Window>